<Window x:Class="SharpShot.UI.SmartRegionLiveOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Regions"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        IsHitTestVisible="True">
    <!-- Null canvas background = clicks pass through to windows below except on highlight shapes -->
    <Canvas x:Name="RootCanvas">
        <Canvas x:Name="HighlightsCanvas"/>
        <Rectangle x:Name="HoverRect"
                   Stroke="{DynamicResource AccentBrush}"
                   StrokeThickness="2"
                   Fill="Transparent"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>
        <TextBlock x:Name="HintText"
                   Text="Smart Regions on — click a highlight to copy text"
                   Foreground="{DynamicResource AccentBrush}"
                   FontSize="14"
                   Canvas.Top="24"
                   IsHitTestVisible="False"/>
    </Canvas>
</Window>
