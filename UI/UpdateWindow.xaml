<Window x:Class="SharpShot.UI.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SharpShot Update" Height="400" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Border CornerRadius="10" Background="#FF1E1E1E" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="315" ShadowDepth="5" BlurRadius="10" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (accent from theme) -->
            <Border Grid.Row="0" Background="#FF2D2D2D" CornerRadius="10,10,0,0" Padding="15"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,0,0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Update Available" FontSize="18" FontWeight="Bold" 
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="UpdateCloseButton" Grid.Column="1" Width="30" Height="30"
                            Click="CloseButton_Click" ToolTip="Close">
                        <TextBlock Text="✕" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="15">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="White" Margin="0,0,0,10">
                        <Run Text="A new version of SharpShot is available!" FontWeight="Bold"/>
                    </TextBlock>
                    
                    <TextBlock Name="VersionText" TextWrapping="Wrap" Foreground="#FFCCCCCC" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Release Notes:" FontWeight="Bold" Foreground="White" Margin="0,10,0,5"/>
                    <Border Background="#FF2D2D2D" CornerRadius="5" Padding="10" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Name="ReleaseNotesText" TextWrapping="Wrap" Foreground="#FFCCCCCC"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Progress Section (shown during download) -->
                    <StackPanel Name="ProgressPanel" Visibility="Collapsed" Margin="0,15,0,0">
                        <TextBlock Name="ProgressStatusText" TextWrapping="Wrap" Foreground="White" Margin="0,0,0,10"/>
                        <ProgressBar Name="ProgressBar" Height="20" Margin="0,0,0,5" Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Name="ProgressPercentageText" TextAlignment="Center" Foreground="#FFCCCCCC" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15,10,15,10">
                <Button x:Name="LaterButton"
                        Click="LaterButton_Click" Margin="0,0,10,0">
                    <TextBlock Text="Later" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="UpdateButton"
                        Click="UpdateButton_Click">
                    <TextBlock Text="Update Now" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <!-- Status Text (for errors) -->
            <TextBlock Grid.Row="3" Name="StatusText" TextWrapping="Wrap" 
                      Foreground="#FFFF6B6B" Margin="15,0,15,10" 
                      Visibility="Collapsed" TextAlignment="Center"/>
        </Grid>
    </Border>
</Window>

