<Window x:Class="SharpShot.UI.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SharpShot"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        MaxWidth="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border CornerRadius="10" Background="#FF1E1E1E" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="315" ShadowDepth="5" BlurRadius="12" Opacity="0.55"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FF2D2D2D" CornerRadius="10,10,0,0" Padding="14,12"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,0,0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleTextBlock" Grid.Column="0"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button x:Name="CloseButton" Grid.Column="1" Width="30" Height="30"
                            VerticalAlignment="Top" Click="CloseButton_Click" ToolTip="Cancel">
                        <TextBlock Text="✕" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <TextBlock x:Name="MessageTextBlock" Grid.Row="1"
                       Margin="18,16,18,8"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="13"
                       LineHeight="20"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="12,8,14,14">
                <Button x:Name="CancelButton" Click="CancelButton_Click" Margin="0,0,10,0">
                    <TextBlock x:Name="CancelButtonText" Text="No" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="ConfirmButton" Click="ConfirmButton_Click">
                    <TextBlock x:Name="ConfirmButtonText" Text="Yes" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
