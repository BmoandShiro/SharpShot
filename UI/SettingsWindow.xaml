                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             x:Name="CopyHotkeyTextBox"
                             Style="{StaticResource DarkTextBoxStyle}"
                             MinWidth="120" Width="200"
                             Text=""
