                        </StackPanel>

                        <StackPanel x:Name="AppearanceSection" Visibility="Collapsed">
                            <TextBlock Text="Appearance" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                            <TextBlock Text="Theme Customization:" x:Name="ThemeCustomizationHeader"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                <!-- Icon Color -->
                <TextBlock Text="Icon Color:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                
                <!-- RGB Color Picker -->
                <Border Background="#FF1A1A1A" 
                        BorderBrush="#FF404040" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Use the RGB sliders to select a color" 
                                   Foreground="{StaticResource TextBrush}" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,10"/>
