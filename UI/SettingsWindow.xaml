                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Text="#FFFF8C00"
                                 Margin="0,10,0,0"
                                 TextChanged="IconColorTextBox_TextChanged"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Favorite colors"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold"
                           Margin="0,4,0,8"/>
