                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <ToggleButton x:Name="ColorPresetDeleteModeToggle"
                                  Click="ColorPresetDeleteModeToggle_Click"
                                  Height="32"
                                  Margin="8,0,0,0"
                                  Padding="12,0"
