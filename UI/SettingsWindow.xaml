                            <TextBlock Text="Tray &amp; close" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="MinimizeOnCloseCheckBox"
                          Content="When closing dashboard, minimize to tray instead of exiting"
                          Style="{StaticResource DarkCheckBoxStyle}"
