                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
                            <TextBlock Text="Position &amp; behavior" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="RestoreDashboardPositionCheckBox"
                          Content="Restore dashboard to last position"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
