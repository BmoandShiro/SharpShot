                              x:Name="SaveTripleClickCheckBox"
                              Content="Triple Click"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"/>
                </Grid>
                        </StackPanel>

                        <StackPanel x:Name="UpdatesSection" Visibility="Collapsed">
                            <TextBlock Text="Updates" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                <CheckBox x:Name="EnableAutoUpdateCheckBox" 
                          Content="Automatically check for updates"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" 
                               Text="Check for updates manually:" 
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" 
                            x:Name="CheckForUpdatesButton"
                            Style="{StaticResource ModernButtonStyle}"
                            Width="100"
                            Height="36"
                            Click="CheckForUpdatesButton_Click">
                        <TextBlock Text="Check Now" 
                                   Foreground="#FFFF8C00" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
                
                <TextBlock Name="UpdateStatusText"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="11"
                           Margin="0,5,0,15"
                           Visibility="Collapsed"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,-18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Button x:Name="ResetRecommendedDefaultsButton"
                        Style="{StaticResource ModernButtonStyle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Height="36"
                        Padding="14,0"
                        Click="ResetRecommendedDefaultsButton_Click"
                        ToolTip="Restore settings and hotkeys to the recommended profile. Click Save to keep changes.">
                    <TextBlock Text="Reset to recommended defaults"
                               Foreground="#FFFF8C00"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Style="{StaticResource ModernButtonStyle}" Click="CancelButton_Click"
                        Margin="0,0,12,0" Width="100" Height="36">
                    <TextBlock Text="Cancel" Foreground="#FFFF8C00" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="SaveButton" Style="{StaticResource ModernButtonStyle}" Click="SaveButton_Click"
                        Width="100" Height="36">
                    <TextBlock Text="Save" Foreground="#FFFF8C00" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,0">
