<Window x:Class="SharpShot.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SharpShot.UI"
        Title="SharpShot Settings"
        Height="640" Width="820"
        MinHeight="480" MinWidth="720"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <SolidColorBrush x:Key="ResizeGripBrush" Color="{DynamicResource AccentColor}"/>
        <Style TargetType="ResizeGrip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ResizeGrip">
                        <Grid>
                            <Canvas Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,1,1">
                                <Rectangle Canvas.Left="0" Canvas.Top="6" Width="4" Height="4" Fill="Transparent" Stroke="{StaticResource ResizeGripBrush}" StrokeThickness="1"/>
                                <Rectangle Canvas.Left="6" Canvas.Top="6" Width="4" Height="4" Fill="Transparent" Stroke="{StaticResource ResizeGripBrush}" StrokeThickness="1"/>
                                <Rectangle Canvas.Left="6" Canvas.Top="0" Width="4" Height="4" Fill="Transparent" Stroke="{StaticResource ResizeGripBrush}" StrokeThickness="1"/>
                            </Canvas>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsNavListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="SettingsNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.19"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.08"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsCategoryTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="SettingsGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style x:Key="SettingsExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="8" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="TopResizeHandle_MouseLeftButtonDown"/>
        <Border Grid.Row="2" Height="8" Background="Transparent" Cursor="SizeNS" MouseLeftButtonDown="BottomResizeHandle_MouseLeftButtonDown"/>
        <Border Grid.Column="0" Width="8" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="LeftResizeHandle_MouseLeftButtonDown"/>
        <Border Grid.Column="2" Width="8" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="RightResizeHandle_MouseLeftButtonDown"/>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Settings" FontSize="24" FontWeight="Bold" x:Name="SettingsHeader"
                       Foreground="{DynamicResource AccentBrush}" MouseLeftButtonDown="Window_MouseLeftButtonDown" Cursor="Hand"/>
            <Button Grid.Column="1" x:Name="CloseSettingsButton" Style="{StaticResource ToolbarButtonStyle}"
                    Width="38" Height="38" Padding="6" Click="CloseSettingsButton_Click" Cursor="Hand">
                <Path Data="M1 1L11 11M11 1L1 11" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                      Fill="Transparent" Stretch="Uniform" Width="22" Height="22"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="168"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SettingsNavListBox" Grid.Column="0" Style="{StaticResource SettingsNavListBoxStyle}"
                     ItemContainerStyle="{StaticResource SettingsNavItemStyle}"
                     SelectionChanged="SettingsNavListBox_SelectionChanged">
                <ListBoxItem Content="General" Tag="General"/>
                <ListBoxItem Content="Capture" Tag="Capture"/>
                <ListBoxItem Content="Recording" Tag="Recording"/>
                <ListBoxItem Content="Dashboard" Tag="Dashboard"/>
                <ListBoxItem Content="Appearance" Tag="Appearance"/>
                <ListBoxItem Content="Hotkeys" Tag="Hotkeys"/>
                <ListBoxItem Content="Updates" Tag="Updates"/>
            </ListBox>

            <Border Grid.Column="2" Background="#FF1A1A1A" CornerRadius="8" Padding="16" BorderBrush="#FF404040" BorderThickness="1">
                <ScrollViewer x:Name="SettingsContentScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBarStyle}"/>
                    </ScrollViewer.Resources>
                    <StackPanel x:Name="SettingsContentPanel">

                        <StackPanel x:Name="GeneralSection" Visibility="Visible">
                            <TextBlock Text="General" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                            <TextBlock Text="Storage" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <!-- Save Path -->
                <TextBlock Text="Save Path:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SavePathTextBox" 
                             Grid.Column="0"
                             Style="{StaticResource DarkTextBoxStyle}"/>
                    <Button x:Name="BrowseButton"
                            Grid.Column="1" 
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="8,0,0,0"
                            Click="BrowseButton_Click"
                            Width="80"
                            Height="32">
                        <TextBlock Text="Browse" 
                                   Foreground="#FFFF8C00" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Screenshot Format -->
                <TextBlock Text="Screenshot Format:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="FormatComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="PNG"/>
                    <ComboBoxItem Content="JPG"/>
                    <ComboBoxItem Content="BMP"/>
                </ComboBox>
                            <TextBlock Text="Startup &amp; tray" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="GlobalHotkeysCheckBox" 
                          Content="Enable Global Hotkeys" 
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"/>
                <CheckBox x:Name="StartMinimizedCheckBox" 
                          Content="Start Minimized" 
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,4"/>
                <CheckBox x:Name="StartWithWindowsMinimizedCheckBox"
                          Content="Start SharpShot with Windows (minimized)"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="16,0,0,10"
                          ToolTip="Adds SharpShot to your Windows startup apps and starts it minimized to the tray when Windows starts"/>
                            <TextBlock Text="Notifications" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="DisableAllPopupsCheckBox"
                          Content="Disable all popup notifications"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="When enabled, all popup dialogs (success messages, file saved confirmations, etc.) will be suppressed"/>
                        </StackPanel>

                        <StackPanel x:Name="CaptureSection" Visibility="Collapsed">
                            <TextBlock Text="Capture" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                            <TextBlock Text="Screen capture" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <!-- Screen Selection for Full-Screen Capture -->
                <TextBlock Text="Full-Screen Capture Target:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="ScreenComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="All Screens"/>
                    <ComboBoxItem Content="Primary Monitor"/>
                    <ComboBoxItem Content="Monitor 1"/>
                    <ComboBoxItem Content="Monitor 2"/>
                    <ComboBoxItem Content="Monitor 3"/>
                    <ComboBoxItem Content="Monitor 4"/>
                </ComboBox>
                            <TextBlock Text="After capture" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="AutoCopyScreenshotsCheckBox" 
                          Content="Auto-copy fullscreen and region screenshots to clipboard (failsafe after editor closes)" 
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="Automatically copies screenshots to clipboard after the editor closes, as a failsafe if you didn't copy in the editor. Applies to both fullscreen and region screenshots."/>
                <CheckBox x:Name="SkipEditorAndAutoCopyCheckBox"
                          Content="Skip editor and auto-copy for region screenshots"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="When enabled, region screenshots will skip the editor overlay and automatically copy to clipboard for immediate pasting"/>
                <CheckBox x:Name="ShowOcrButtonOnDashboardCheckBox"
                          Content="Show OCR quick-capture button on dashboard"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="Adds an OCR button to the main dashboard. Click it to region-select and extract text directly without opening the screenshot editor."/>
                <CheckBox x:Name="SkipPostCaptureMenuCheckBox"
                          Content="Skip post-capture menu for screenshots and videos"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="When enabled, SharpShot skips the copy/save/cancel dashboard menu after region, fullscreen, and video captures."/>
                <CheckBox x:Name="HideSharpShotWindowsDuringCaptureCheckBox"
                          Content="Hide SharpShot windows in screenshots (dashboard, editor, magnifier)"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="When enabled, SharpShot temporarily hides its own windows while the screen pixels are captured so they do not appear in the image. In the editor, the bottom toolbar, color panel, and OCR popup are hidden briefly when you save or copy so they are not baked into the file."/>
                            <TextBlock Text="Magnifier" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="EnableMagnifierCheckBox"
                          Content="Enable magnifier during region selection"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"/>
               <!-- Magnifier Zoom Level -->
               <StackPanel x:Name="MagnifierZoomPanel"
                          Margin="0,0,0,20"
                          Visibility="Collapsed">
                   <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                       <TextBlock Text="Magnifier Zoom Level:"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                       <ComboBox x:Name="MagnifierZoomComboBox"
                                 Width="80"
                                 Style="{StaticResource DarkComboBoxStyle}">
                           <ComboBoxItem Content="0.5x"/>
                           <ComboBoxItem Content="1.0x"/>
                           <ComboBoxItem Content="1.5x"/>
                           <ComboBoxItem Content="2.0x"/>
                           <ComboBoxItem Content="2.5x"/>
                           <ComboBoxItem Content="3.0x"/>
                           <ComboBoxItem Content="3.5x"/>
                       <ComboBoxItem Content="4.0x"/>
                       <ComboBoxItem Content="4.5x"/>
                       <ComboBoxItem Content="5.0x"/>
                       <ComboBoxItem Content="5.5x"/>
                       <ComboBoxItem Content="6.0x"/>
                       <ComboBoxItem Content="6.5x"/>
                       <ComboBoxItem Content="7.0x"/>
                       <ComboBoxItem Content="7.5x"/>
                       <ComboBoxItem Content="8.0x"/>
                       <ComboBoxItem Content="8.5x"/>
                       <ComboBoxItem Content="9.0x"/>
                       <ComboBoxItem Content="9.5x"/>
                       <ComboBoxItem Content="10.0x"/>
                   </ComboBox>
                   </StackPanel>
                   
                   <!-- Magnifier Size (Stationary Mode) -->
                   <StackPanel x:Name="MagnifierSizeStationaryPanel"
                              Orientation="Horizontal" 
                              Margin="0,0,0,10"
                              Visibility="Collapsed">
                       <TextBlock Text="Magnifier Size (Stationary):"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Width="180"/>
                       <Slider x:Name="MagnifierSizeSlider"
                               Style="{StaticResource DarkSliderStyle}"
                               Minimum="100"
                               Maximum="400"
                               TickFrequency="50"
                               IsSnapToTickEnabled="True"
                               Width="200"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                       <TextBlock x:Name="MagnifierSizeText"
                                  Text="200px"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Width="60"/>
                   </StackPanel>
                   
                   <!-- Magnifier Size (Follow Cursor/Auto Mode) -->
                   <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                       <TextBlock Text="Magnifier Size (Follow/Auto):"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Width="180"/>
                       <Slider x:Name="MagnifierFollowSizeSlider"
                               Style="{StaticResource DarkSliderStyle}"
                               Minimum="100"
                               Maximum="200"
                               TickFrequency="25"
                               IsSnapToTickEnabled="True"
                               Width="200"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                       <TextBlock x:Name="MagnifierFollowSizeText"
                                  Text="200px"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Width="60"/>
                   </StackPanel>
               </StackPanel>
               
               <!-- Magnifier Mode -->
               <StackPanel x:Name="MagnifierModePanel"
                          Margin="0,0,0,20"
                          Visibility="Collapsed">
                   <TextBlock Text="Magnifier Mode:"
                              Foreground="{StaticResource TextBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,0,5"/>
                   <ComboBox x:Name="MagnifierModeComboBox"
                             Width="200"
                             Style="{StaticResource DarkComboBoxStyle}">
                       <ComboBoxItem Content="Follow Cursor" Tag="Follow"/>
                       <ComboBoxItem Content="Stationary" Tag="Stationary"/>
                       <ComboBoxItem Content="Auto (Stationary on non-100% monitors)" Tag="Auto"/>
                   </ComboBox>
               </StackPanel>
               
               <!-- Stationary Magnifier Settings -->
               <StackPanel x:Name="MagnifierStationaryPanel"
                          Margin="0,0,0,20"
                          Visibility="Collapsed">
                   <TextBlock Text="Stationary Magnifier Settings:"
                              Foreground="{StaticResource TextBrush}"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>
                   
                   <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                       <TextBlock Text="Monitor:"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Width="80"/>
                       <ComboBox x:Name="MagnifierStationaryMonitorComboBox"
                                 Width="200"
                                 Style="{StaticResource DarkComboBoxStyle}"/>
                   </StackPanel>
                   
                   <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                       <TextBlock Text="Position X (%):"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Width="100"/>
                       <Slider x:Name="MagnifierStationaryXSlider"
                               Style="{StaticResource DarkSliderStyle}"
                               Minimum="0"
                               Maximum="100"
                               Value="50"
                               Width="200"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                       <TextBlock x:Name="MagnifierStationaryXText"
                                  Text="50"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Width="40"/>
                   </StackPanel>
                   
                   <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                       <TextBlock Text="Position Y (%):"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Width="100"/>
                       <Slider x:Name="MagnifierStationaryYSlider"
                               Style="{StaticResource DarkSliderStyle}"
                               Minimum="0"
                               Maximum="100"
                               Value="50"
                               Width="200"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                       <TextBlock x:Name="MagnifierStationaryYText"
                                  Text="50"
                                  Foreground="{StaticResource TextBrush}"
                                  VerticalAlignment="Center"
                                  Width="40"/>
                   </StackPanel>
                   
                   <TextBlock Text="Position is relative to the selected monitor (0% = top/left, 100% = bottom/right)"
                              Foreground="#FF888888"
                              FontSize="11"
                              TextWrapping="Wrap"
                              Margin="0,5,0,0"/>
               </StackPanel>
               
               
               <Expander Header="Advanced magnifier (auto mode &amp; boundary boxes)" Style="{StaticResource SettingsExpanderStyle}" IsExpanded="False">
                   <StackPanel Margin="0,8,0,0">
<!-- Auto Mode Monitor Selection -->
               <StackPanel x:Name="MagnifierAutoModePanel"
                          Margin="0,0,0,20"
                          Visibility="Collapsed">
                   <TextBlock Text="Select monitors that should use stationary mode:"
                              Foreground="{StaticResource TextBrush}"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>
                   
                   <ScrollViewer MaxHeight="200"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,10"
                                PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                       <ScrollViewer.Resources>
                           <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBarStyle}"/>
                       </ScrollViewer.Resources>
                       <StackPanel x:Name="MagnifierAutoMonitorList">
                           <!-- Checkboxes will be populated dynamically -->
                       </StackPanel>
                   </ScrollViewer>
                   
                   <TextBlock Text="Checked monitors will automatically switch to stationary mode when your cursor enters them. Unchecked monitors will use follow cursor mode."
                              Foreground="#FF888888"
                              FontSize="11"
                              TextWrapping="Wrap"
                              Margin="0,5,0,10"/>
                   
                   <TextBlock Text="Boundary Boxes (for DPI-scaled monitors):"
                              Foreground="{StaticResource TextBrush}"
                              FontWeight="SemiBold"
                              Margin="0,10,0,10"/>
                   
                   <TextBlock Text="If monitor detection doesn't work correctly (especially on any monitor that is not on 100% scaled zoom), you can draw custom boundary boxes. Checked boxes will trigger stationary mode when your cursor enters them. You can have multiple boxes per monitor."
                              Foreground="#FF888888"
                              FontSize="11"
                              TextWrapping="Wrap"
                              Margin="0,0,0,10"/>
                   
                   <Button x:Name="AddBoundaryBoxButton"
                          Style="{StaticResource ModernButtonStyle}"
                          Click="AddBoundaryBoxButton_Click"
                          Width="150"
                          Height="32"
                          Margin="0,0,0,10"
                          HorizontalAlignment="Left">
                        <TextBlock Text="Add Boundary Box" 
                                   Foreground="#FFFF8C00" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                   
                   <ScrollViewer MaxHeight="200"
                                VerticalScrollBarVisibility="Auto"
                                Margin="0,0,0,10"
                                PreviewMouseWheel="NestedScrollViewer_PreviewMouseWheel">
                       <ScrollViewer.Resources>
                           <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemedScrollBarStyle}"/>
                       </ScrollViewer.Resources>
                       <StackPanel x:Name="MagnifierBoundaryBoxList">
                           <!-- Boundary boxes will be populated dynamically -->
                       </StackPanel>
                   </ScrollViewer>
               </StackPanel>
                   </StackPanel>
               </Expander>

                            <TextBlock Text="Region selection" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <CheckBox x:Name="EnableSmartRegionDetectionCheckBox"
                          Content="Highlight detected regions (images, text blocks) during region selection"
                          Style="{StaticResource DarkCheckBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="When enabled, detects elements like images and text on the screen (e.g. in browsers) and lets you click a highlight to capture that region. Similar to Snipping Tool behavior."/>
                        </StackPanel>

                        <StackPanel x:Name="RecordingSection" Visibility="Collapsed">
                            <TextBlock Text="Recording" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                            <TextBlock Text="Video &amp; audio" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <!-- Video Quality -->
                <TextBlock Text="Video Quality:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="QualityComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="High"/>
                    <ComboBoxItem Content="Medium"/>
                    <ComboBoxItem Content="Low"/>
                </ComboBox>
                <TextBlock Text="Screen recordings use FFmpeg."
                           Foreground="#FF888888"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Audio Recording Mode -->
                <!-- Commented out - Audio recording disabled for now
                <TextBlock Text="Audio Recording Mode:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="AudioRecordingModeComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,10"
                          SelectionChanged="AudioRecordingModeComboBox_SelectionChanged">
                    <ComboBoxItem Content="No Audio"/>
                    <ComboBoxItem Content="System Audio Only"/>
                    <ComboBoxItem Content="Microphone Only"/>
                    <ComboBoxItem Content="System Audio + Microphone"/>
                </ComboBox>
                -->

                <!-- Output Audio Device Selection -->
                <StackPanel x:Name="OutputAudioDevicePanel" 
                           Margin="0,0,0,10" 
                           ToolTip="FFmpeg region and full-screen recordings: capture system audio from the chosen playback device (WASAPI loopback). Choose No system audio for video-only.">
                    <TextBlock Text="FFmpeg - system audio (playback device):" 
                               Foreground="{StaticResource TextBrush}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="OutputAudioDeviceComboBox" 
                              Style="{StaticResource DarkComboBoxStyle}"
                              Margin="0,0,0,10"
                              ToolTip="Uses WASAPI loopback on the selected output. Auto-detect uses the default playback device."/>
                </StackPanel>

                <!-- Input Audio Device Selection -->
                <StackPanel x:Name="InputAudioDevicePanel" 
                           Margin="0,0,0,10" 
                           Visibility="Collapsed">
                    <TextBlock Text="Input Audio Device (Microphone):" 
                               Foreground="{StaticResource TextBrush}" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="InputAudioDeviceComboBox" 
                              Style="{StaticResource DarkComboBoxStyle}"
                              Margin="0,0,0,10"/>
                </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="DashboardSection" Visibility="Collapsed">
                            <TextBlock Text="Dashboard &amp; windows" Style="{StaticResource SettingsCategoryTitleStyle}"/>
                            <TextBlock Text="Display" Style="{StaticResource SettingsGroupHeaderStyle}"/>
                <!-- Screenshot Editor Display Monitor -->
                <TextBlock Text="Screenshot Editor Display Monitor:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="EditorDisplayMonitorComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,15"
                          ToolTip="Choose which monitor displays the screenshot editor toolbar and preview when editing screenshots">
                    <ComboBoxItem Content="Primary Monitor"/>
                    <ComboBoxItem Content="Monitor 1"/>
                    <ComboBoxItem Content="Monitor 2"/>
                    <ComboBoxItem Content="Monitor 3"/>
                    <ComboBoxItem Content="Monitor 4"/>
                </ComboBox>
                <!-- Dashboard Display Monitor -->
                <TextBlock Text="Dashboard Display Monitor:" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,5"/>
                <ComboBox x:Name="DashboardDisplayMonitorComboBox" 
                          Style="{StaticResource DarkComboBoxStyle}"
                          Margin="0,0,0,10"
                          ToolTip="Choose which monitor shows the main SharpShot dashboard window">
                    <ComboBoxItem Content="Primary Monitor"/>
