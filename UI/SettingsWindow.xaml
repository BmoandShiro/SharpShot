                             Style="{StaticResource DarkTextBoxStyle}"
                             ToolTip="Dashboard height in logical pixels. Leave empty for default (80). Range: 50ÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬Ãƒâ€¦Ã¢â‚¬Å“400."/>
                    <Button x:Name="DashboardSizeResetButton" Grid.Column="6"
