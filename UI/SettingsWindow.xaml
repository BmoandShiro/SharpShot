                    </Button>
                    <CheckBox Grid.Column="3"
                              x:Name="ScreenshotRegionTripleClickCheckBox"
                              Content="Triple Click"
                              Style="{StaticResource DarkCheckBoxStyle}"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"/>
