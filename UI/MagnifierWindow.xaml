<Window x:Class="SharpShot.UI.MagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Magnifier"
        Height="200" Width="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowActivated="False">
    
    <Border Background="#FF1A1A1A" 
            CornerRadius="8" 
            BorderBrush="{DynamicResource AccentBrush}" 
            BorderThickness="2"
            Effect="{x:Null}">
        
        <Grid>
            <!-- Magnified content area -->
            <Border x:Name="MagnifierContent"
                    Background="Transparent"
                    Margin="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Image x:Name="MagnifiedImage"
                       Stretch="Fill"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>
            </Border>
            
            <!-- Crosshair overlay (stretch-based so it stays centered and DPI-independent) -->
            <Grid x:Name="CrosshairGrid" IsHitTestVisible="False">
                <!-- Horizontal line -->
                <Rectangle Height="1"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Fill="{DynamicResource AccentBrush}"
                           Opacity="0.8"/>

                <!-- Vertical line -->
                <Rectangle Width="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Stretch"
                           Fill="{DynamicResource AccentBrush}"
                           Opacity="0.8"/>

                <!-- Center dot -->
                <Ellipse Width="4" Height="4"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="{DynamicResource AccentBrush}"/>
            </Grid>
            
            <!-- Zoom level indicator -->
            <Border Background="#80000000"
                    CornerRadius="4"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="8,8,0,0"
                    Padding="4,2">
                <TextBlock x:Name="ZoomLevelText"
                           Text="2x"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="10"
                           FontWeight="Bold"/>
            </Border>
        </Grid>
    </Border>
</Window> 