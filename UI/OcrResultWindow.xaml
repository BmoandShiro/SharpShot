<Window x:Class="SharpShot.UI.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OCR Result"
        Height="360"
        Width="560"
        MinHeight="260"
        MinWidth="420"
        Style="{StaticResource DarkWindowStyle}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="OcrPopupButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FF8C00"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#30FF8C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="Transparent"
                Padding="0,0,0,10"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Extracted Text"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button x:Name="HeaderCloseButton"
                        HorizontalAlignment="Right"
                        Width="30"
                        Height="30"
                        Style="{StaticResource OcrPopupButtonStyle}"
                        Click="CloseButton_Click"
                        ToolTip="Close">
                    <TextBlock Text="✕"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <TextBox x:Name="ResultTextBox"
                 Grid.Row="1"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 Style="{StaticResource DarkTextBoxStyle}"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="CopyTextButton"
                    Style="{StaticResource OcrPopupButtonStyle}"
                    Width="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="CopyTextButton_Click">
                <TextBlock Text="Copy Text"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold"/>
            </Button>
            <Button x:Name="CloseButton"
                    Style="{StaticResource OcrPopupButtonStyle}"
                    Width="90"
                    Height="34"
                    Click="CloseButton_Click">
                <TextBlock Text="Close"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
