<Window x:Class="SharpShot.UI.RegionSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Region Selection"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Canvas x:Name="SelectionCanvas" Background="#01000000">
        <!-- Frozen desktop snapshot so open menus/dropdowns stay capturable even if focus changes -->
        <Image x:Name="FreezeFrameImage"
               Stretch="Fill"
               IsHitTestVisible="False"/>
        <Rectangle x:Name="FreezeDimOverlay"
                   Fill="#40000000"
                   IsHitTestVisible="False"/>
        <!-- Smart region highlights (images, text blocks) - drawn when option is enabled -->
        <Canvas x:Name="SmartHighlightsCanvas" IsHitTestVisible="False"/>
        <Rectangle x:Name="SmartHoverRect"
                   Stroke="{DynamicResource AccentBrush}"
                   StrokeThickness="2"
                   Fill="Transparent"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>
        <Rectangle x:Name="SelectionRect" 
                   Stroke="{StaticResource AccentBrush}" 
                   StrokeThickness="2" 
                   StrokeDashArray="5,5"
                   Fill="Transparent"
                   Visibility="Collapsed"/>
        
        <!-- Instructions -->
        <TextBlock x:Name="InstructionsText"
                   Text="Click and drag to select a region, or press ESC to cancel"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Canvas.Top="50"/>
    </Canvas>
</Window> 